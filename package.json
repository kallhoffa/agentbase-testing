{
  "name": "secureagentbase",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ci": "vitest run --pool=threads --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "check": "npm run test:ci && npm run lint && npm run typecheck && npm run build",
    "e2e": "playwright test",
    "e2e:ci": "playwright test --config=playwright.ci.config.js",
    "e2e:smoke": "playwright test tests/e2e/smoke.spec.js",
    "e2e:smoke:ci": "playwright test tests/e2e/smoke.spec.js --config=playwright.ci.config.js",
    "setup": "node scripts/setup.js"
  },
  "dependencies": {
    "@sentry/react": "^10.40.0",
    "firebase": "^11.0.1",
    "lucide-react": "^0.454.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.0",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@sentry/vite-plugin": "^5.1.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.4.24",
    "axe-core": "^4.11.1",
    "eslint": "^9.39.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "jsdom": "^24.1.3",
    "typescript": "^6.0.2",
    "vite": "^6.4.1",
    "vite-plugin-checker": "^0.12.0",
    "vitest": "^4.1.9"
  }
}
