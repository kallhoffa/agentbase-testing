# App environment: 'development', 'staging', or 'production'
# Automatically loads .env.{mode} based on Vite mode
# Use: npm run dev -- --mode staging
VITE_APP_ENV=development

# ===========================================
# STAGING Firebase Configuration
# ===========================================
VITE_FIREBASE_API_KEY_STAGING=your_staging_api_key
VITE_FIREBASE_AUTH_DOMAIN_STAGING=your_staging_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID_STAGING=your_staging_project_id
VITE_FIREBASE_STORAGE_BUCKET_STAGING=your_staging_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID_STAGING=your_staging_sender_id
VITE_FIREBASE_APP_ID_STAGING=your_staging_app_id
VITE_FIREBASE_MEASUREMENT_ID_STAGING=your_staging_measurement_id

# ===========================================
# PRODUCTION Firebase Configuration
# ===========================================
VITE_FIREBASE_API_KEY_PRODUCTION=your_production_api_key
VITE_FIREBASE_AUTH_DOMAIN_PRODUCTION=your_production_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID_PRODUCTION=your_production_project_id
VITE_FIREBASE_STORAGE_BUCKET_PRODUCTION=your_production_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID_PRODUCTION=your_production_sender_id
VITE_FIREBASE_APP_ID_PRODUCTION=your_production_app_id
VITE_FIREBASE_MEASUREMENT_ID_PRODUCTION=your_production_measurement_id

# ===========================================
# Framework Configuration
# ===========================================
VITE_STAGING_URL=https://your-staging.web.app
VITE_PRODUCTION_URL=https://your-production.com
VITE_FEATURE_FLAG_KEY=default_flag

# Google Cloud OAuth (for GCP project selection)
VITE_GCP_CLIENT_ID=your-gcp-client-id.apps.googleusercontent.com

# Sentry error tracking (optional)
# VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project
# VITE_SENTRY_ORG=your-org
# VITE_SENTRY_PROJECT=your-project
# SENTRY_AUTH_TOKEN=your_sentry_auth_token

# Set to 'true' to use Firebase emulators (local development)
# VITE_USE_FIREBASE_EMULATOR=true
